<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/drawer_layout">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        tools:context=".MainActivity">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolsbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/toolbar_shape"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:menu="@menu/menuprincipal">


            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="end">

                <ImageView
                    android:id="@+id/ic_toolbar_add_frase"
                    android:contentDescription="@string/img"
                    android:src="@drawable/ic_note_add"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    app:tint="@color/black"
                    android:layout_marginEnd="15dp"/>

                <ImageView
                    android:id="@+id/ic_toolbar_add_note"
                    android:src="@drawable/ic_add_note"
                    android:contentDescription="@string/img"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginEnd="15dp"
                    app:tint="@color/black"/>
                <ImageView
                    android:id="@+id/ic_toolbar_fav"
                    android:src="@drawable/ic_toolbar_favorite"
                    android:contentDescription="@string/img"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginEnd="15dp"
                    app:tint="@color/black"
                    android:visibility="gone" />

            </LinearLayout>




        </androidx.appcompat.widget.Toolbar>



            <!-- Contenedor de fragmentos -->
        <fragment
            android:id="@+id/frag_container"
            android:name="androidx.navigation.fragment.NavHostFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="106dp"
            app:defaultNavHost="true"
            android:layout_marginTop="?attr/actionBarSize"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/toolsbar"
            app:navGraph="@navigation/nav_graf"
            tools:ignore="FragmentTagUsage" />


        <!-- menú inferior -->
        <androidx.cardview.widget.CardView
            android:id="@+id/bottom_navigation_view"
            android:layout_width="0dp"
            android:layout_height="68dp"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="18dp"
            android:layout_marginBottom="14dp"
            android:backgroundTint="@android:color/transparent"
            android:elevation="16dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="30dp"
            app:cardElevation="16dp"
            app:cardUseCompatPadding="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:id="@+id/bottom_nav_inner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_floating_nav_metal"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <ImageButton
                    android:id="@+id/nav_btn_conf"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_nav_item_active"
                    android:contentDescription="@string/nav_conferencias"
                    android:padding="10dp"
                    android:src="@drawable/ic_conf"
                    app:tint="#1E2A32" />

                <ImageButton
                    android:id="@+id/nav_btn_notas"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/nav_notas"
                    android:padding="10dp"
                    android:src="@drawable/ic_note"
                    app:tint="#2E3B44" />

                <ImageButton
                    android:id="@+id/nav_btn_home"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/nav_home"
                    android:padding="10dp"
                    android:src="@drawable/ic_nav_home"
                    app:tint="#2E3B44" />

                <ImageButton
                    android:id="@+id/nav_btn_diario"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/nav_diario"
                    android:padding="10dp"
                    android:src="@drawable/ic_nav_journal"
                    app:tint="#2E3B44" />

                <ImageButton
                    android:id="@+id/nav_btn_chat"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/nav_chat"
                    android:padding="10dp"
                    android:src="@drawable/ic_nav_chat"
                    app:tint="#2E3B44" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>




    </androidx.constraintlayout.widget.ConstraintLayout>


    <!-- Elementos para el menú de DrawerLayout -->
<com.google.android.material.navigation.NavigationView
    android:id="@+id/nav_view"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:layout_gravity="start"
    app:menu="@menu/drawer_menu"
    app:headerLayout="@layout/drawer_header"
    android:theme="@style/Theme.AppCompat.DayNight">

</com.google.android.material.navigation.NavigationView>


</androidx.drawerlayout.widget.DrawerLayout>
